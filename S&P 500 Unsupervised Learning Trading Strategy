# Define portfoilo optimization function
def Optimize_weight(price):
    try:
        if price.empty or len(price.columns) < 3:
            return {'There are no stock RSI above 80 in this month or The number of valid stock is below 3'}

        returns = expected_returns.mean_historical_return(prices=price,
                                                          frequency=252)

        cov = risk_models.sample_cov(prices=price,
                                     frequency=252)

        raw_lb = 1 / (len(price.columns) * 2)
        lower_bound = min(round(raw_lb, 3), 0.9 / len(price.columns))
        upper_bound = max(0.1, 1.1 / len(price.columns))

        def create_ef():
            return EfficientFrontier(expected_returns=returns,
                                     cov_matrix=cov,
                                     weight_bounds=(lower_bound, upper_bound),
                                     solver='SCS'
                                     )

        try:
            ef_shape = create_ef()
            ef_shape.max_sharpe(risk_free_rate=0)
            return ef_shape.clean_weights()

        except ValueError:
            print('Expected returns are all below the risk-free rate; switch to a minimum volatility allocation')
            return {}
        except Exception as e:
            print('Solver status: infeasible')
            try:
                ef_min_vol = create_ef()
                ef_min_vol.min_volatility()
                return ef_min_vol.clean_weights()
            except Exception as e:
                return {}

    except Exception as e:
        print(f"Optimization failed：{e}")
        return {}


