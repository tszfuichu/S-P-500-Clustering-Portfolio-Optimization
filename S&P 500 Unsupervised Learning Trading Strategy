# Calculate the Rolling Factor Beta
class Calculate_Beta:
    def calculate_beta(df):
        betas = df.groupby(level=1, group_keys=False).apply(lambda x: RollingOLS(endog=x['Return_1m'],
                                                                                 exog=sm.add_constant(
                                                                                     x.drop('Return_1m', axis=1)),
                                                                                 window=min(24, x.shape[0]),
                                                                                 min_nobs=len(x.columns) + 1)
                                                            .fit(params_only=True)
                                                            .params
                                                            .drop('const', axis=1)
                                                            )

        return betas


