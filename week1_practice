#Get all the tickers from url (example:S&P500)

class GetTickers:
    def __init__(self,url):
        self.url = url
        self.tickers = []

    def get_tickers(self):
        headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36'}
        response = requests.get(self.url, headers = headers)
        html = StringIO(response.text)
        tables = pd.read_html(html)
        truetable = None

        for table in tables:
            if "Symbol" in table.columns:
                truetable = pd.DataFrame(table)
                break

        truetable['Symbol'] = truetable['Symbol'].str.replace('.','-')
        self.tickers = truetable['Symbol'].unique().tolist()
        return self.tickers

#Get the stock data by providing Tickers

class GetStockData:
    def __init__(self,tickers):
        self.tickers = tickers

    def fetch_data(self):
        start_date = (date.today() - timedelta(5475)).strftime('%Y-%m-%d')
        end_date = date.today().strftime('%Y-%m-%d')
        df = yf.download(tickers = self.tickers, start = start_date, end = end_date, auto_adjust= True,threads=True)
        df = df.stack()
        df.index.names = ('Date','Ticker')
        return df

#Calculate feature and technical indicator for each stock (Garman-Klass Volatility, RSI, Bollinger Bands, ATR, MACD, Dollar Volume)

class Calculate_indicators:
    @staticmethod
    def compute_technical_indicators(df):

        #Calculate the Garman-Klass Volatility
        df['garman_klass_vol'] = ((np.log(df['High']) - np.log(df['Low'])) ** 2) / 2 - \
                                 (2 * np.log(2) - 1) * ((np.log(df['Close']) - np.log(df['Open'])) ** 2)

        #Calculate the RSI
        df['RSI'] = df.groupby(level=1, group_keys = False)['Close'].transform(lambda x: ta.rsi(close=x , length = 14))

        #Calculate the Bollinger Bands (Upper,Middle,Bottom)
        def compute_bb(close):
            # Use log1p to stabilize variance and normalize price distribution for Bollinger Bands.
            bb = ta.bbands(close=np.log1p(close), length=14)
            return bb.iloc[:, 0:3]

        df[['BBL', 'BBM', 'BBU']] =  df.groupby(level=1, group_keys=False)['Close'].apply(compute_bb)

        #Create a Z-score Function (Rolling one year data avoid the look-ahead bias)
        def Zscore(x, window=252):
            role = x.rolling(window=window, min_periods=window)
            x = (x-role.mean())/role.std()
            return x

        #Calculate the ATR and standardize it

        raw_atr = df.groupby(level = 1, group_keys = False).apply(lambda x:  ta.atr(high=x['High'],low= x['Low'],close=x['Close'], length=14))
        df['ATR'] = raw_atr.groupby(level = 1, group_keys= False).transform(Zscore)

        #Calculate the MACD

        def compute_MACD(close):
            macd = ta.macd(close=close, fast=12, slow=26, signal=9).iloc[:,0]
            if macd is None or macd.empty:
                return pd.Series(np.nan, index=close.index)
            return Zscore(macd)

        df['MACD'] = df.groupby(level = 1, group_keys= False)['Close'].apply(compute_MACD)

        #Calculate the Dollar Volume
        df['Dollar_Volume'] = df['Close']*df['Volume']/1e6

        #Return the DataFrame
        return df

# Filtering the Top 150 Most Liquid Stocks in each Month
class Filtering:
    @staticmethod
    def filter_liquid_stock(df):

        #Create a DataFrame that Average Dollar Volume in a month
        df_dv_month = df['Dollar_Volume'].unstack(level=1).resample('ME').mean().stack('Ticker').to_frame('Dollar_Volume')

        # Create a DataFrame that Other Indicator in a month
        last_col = [c for c in df.columns.unique(level=0) if
                    c not in ["Dollar_Volume", "Volume", "Open", "High", "Low"]]
        df_other_month = df[last_col].unstack(level = 1).resample('ME').last().stack("Ticker")

        df_after_filter = pd.concat([df_dv_month,df_other_month],axis=1).dropna()

        def filter_top_150(df):
            df['Dollar_Volume'] = df['Dollar_Volume'].unstack(level=1).rolling(5*12,min_periods=6).mean().stack('Ticker')
            df['Rank'] = df.groupby(level=0, group_keys = False)['Dollar_Volume'].apply(lambda x: x.rank(ascending = False))
            df = df[df['Rank'] <= 150]
            df = df.drop(['Dollar_Volume','Rank'], axis = 1)
            return df

        df_after_filter =  filter_top_150(df_after_filter)

        return df_after_filter

    # fliter out the stock less than 10 months
    def filter_less_than_10m(df):
        observation = df.groupby(level = 1).size()
        valid_stock_list = observation[observation > 10]
        valid_stock_data = df[df.index.get_level_values('Ticker').isin(valid_stock_list.index)]

        return valid_stock_data

class Monthly_return:
    def monthly_return(df):
        temp_df = df.copy()
        temp_df = temp_df.sort_index(level = ['Ticker',0])
        outlier_cutoff = 0.005
        lags = [1,2,3,6,9,12]

        for lag in lags:
            returns = temp_df.groupby(level = 'Ticker',group_keys = False)['Close'].pct_change(lag)

            cliped_return = returns.pipe(lambda x: x.clip(lower = x.quantile(outlier_cutoff),
                                                          upper = x.quantile(1 - outlier_cutoff)))

            temp_df[f'Return_{lag}m']= (cliped_return.add(1)).pow(1/lag).sub(1)

        return temp_df

#Downloading the Fama-French Factors
class Get_fff:
    def get_fff(path):
        FFF = pd.read_csv(path, skiprows = 3, index_col = 0)
        FFF = FFF[FFF.index.str.strip().str.len() == 6]
        FFF.index = pd.to_datetime(FFF.index, format='%Y%m')
        FFF.index = FFF.index + pd.offsets.MonthEnd(0)
        FFF.index.name = 'Date'
        FFF = FFF.drop("RF",axis=1)
        FFF = FFF.loc['2012-09-30':]
        FFF = FFF.astype(float) / 100
        return FFF

#Calculate the Rolling Factor Beta
class Calculate_Beta:
    def calculate_beta(df):
        betas = df.groupby(level = 1,group_keys = False).apply(lambda x: RollingOLS(endog = x['Return_1m'],
                                                                                    exog = sm.add_constant(x.drop('Return_1m',axis = 1)),
                                                                                    window = min(24,x.shape[0]),
                                                                                    min_nobs = len(x.columns)+1)
                                                                                    .fit(params_only=True)
                                                                                    .params
                                                                                    .drop('const',axis = 1)
                                                                                    )

        return betas

