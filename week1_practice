#K-Means Clustering Algorithm
class K_means:
    @staticmethod
    def kmeans(df):
        #features = df.columns
        #scaler = StandardScaler()
        #scaled_data = scaler.fit_transform(df[features])

        df['Cluster'] = KMeans(n_clusters=4,
                               random_state = 0,
                               init = 'random').fit_predict(df)
        return df

class Plot_data:
    @staticmethod
    def plot_clusters(df):
        plt.style.use('ggplot')
        cluster0 = df[df['Cluster'] == 0]
        cluster1 = df[df['Cluster'] == 1]
        cluster2 = df[df['Cluster'] == 2]
        cluster3 = df[df['Cluster'] == 3]

        plt.scatter(cluster0['RSI'], cluster0['ATR'], color='red', label='Cluster 0')
        plt.scatter(cluster1['RSI'], cluster1['ATR'], color='blue', label='Cluster 1')
        plt.scatter(cluster2['RSI'], cluster2['ATR'], color='green', label='Cluster 2')
        plt.scatter(cluster3['RSI'], cluster3['ATR'], color='yellow', label='Cluster 3')

        plt.legend()
        plt.show()
        return

